# ── App ──────────────────────────────────────────────────
APP_NAME="Sofia Books"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:REPLACE_ME_RUN_STEP_3

# ── Database ──────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_DATABASE=sofia_books
DB_USERNAME=sofia
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────
# (no changes needed — defaults work with the redis container)

# ── MinIO (local S3) ──────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=sofia-documents
AWS_ENDPOINT=http://minio:9000

# ── Laravel Reverb (WebSocket) ────────────────────────────
REVERB_APP_ID=sofia-app
REVERB_APP_KEY=sofia-key
REVERB_APP_SECRET=sofia-secret

# ── External APIs ─────────────────────────────────────────
ANTHROPIC_API_KEY=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
SEMAPHORE_API_KEY=your-semaphore-key-here

# ── Internal service URLs (used by Laravel) ───────────────
OCR_SERVICE_URL=http://ocr-service:8001
